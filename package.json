{
  "name": "obstor",
  "version": "8.0.8",
  "description": "S3 Compatible Cloud Storage client",
  "main": "./dist/main/obstor.js",
  "module": "./dist/esm/obstor.mjs",
  "scripts": {
    "prepare": "husky",
    "tsc": "tsc",
    "type-check": "tsc --noEmit --emitDeclarationOnly false",
    "build": "node build.mjs",
    "test": "mocha",
    "lint": "eslint . --fix",
    "functional": "mocha tests/functional/functional-tests.js",
    "format": "prettier -w .",
    "format-check": "prettier --list-different .",
    "lint-staged": "lint-staged"
  },
  "exports": {
    ".": {
      "require": "./dist/main/obstor.js",
      "types": "./dist/main/obstor.d.ts",
      "default": "./dist/esm/obstor.mjs"
    },
    "./dist/main/internal/*": null,
    "./dist/main/*": {
      "require": "./dist/main/*",
      "default": null
    },
    "./dist/esm/internal/*": null,
    "./dist/esm/*": {
      "import": "./dist/esm/*",
      "default": null
    },
    "./package.json": "./package.json"
  },
  "files": [
    "package.json",
    "./dist/",
    "./src/",
    "./types/",
    "LICENSE",
    "README.md",
    "README_zh_CN.md",
    "MAINTAINERS.md"
  ],
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "endOfLine": "lf",
    "trailingComma": "all",
    "semi": false
  },
  "lint-staged": {
    "*.json": [
      "prettier --write"
    ],
    "*.{js,cjs,mjs,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obstor/obstor-js.git"
  },
  "engines": {
    "node": "^16 || ^18 || >=20"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/obstor/obstor-js/issues",
    "mail": ""
  },
  "homepage": "https://github.com/obstor/obstor-js#readme",
  "dependencies": {
    "async": "^3.2.6",
    "block-stream2": "^2.1.0",
    "browser-or-node": "^3.0.0",
    "buffer-crc32": "^1.0.0",
    "eventemitter3": "^5.0.4",
    "fast-xml-parser": "^5.8.0",
    "ipaddr.js": "^2.4.0",
    "lodash": "^4.18.1",
    "mime-types": "^3.0.2",
    "query-string": "^9.4.0",
    "stream-json": "^3.4.0",
    "through2": "^5.0.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-modules-commonjs": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@babel/register": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@nodelib/fs.walk": "^3.0.1",
    "@types/async": "^3.2.25",
    "@types/block-stream2": "^2.1.3",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/lodash": "^4.17.24",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.9.3",
    "@types/stream-json": "^1.7.8",
    "@types/through2": "^2.0.41",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@upleveled/babel-plugin-remove-node-prefix": "^1.0.5",
    "babel-plugin-replace-import-extension": "^1.1.5",
    "babel-plugin-transform-replace-expressions": "^0.2.0",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^65.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "mocha": "^11.7.6",
    "mocha-steps": "^1.3.0",
    "nock": "^14.0.15",
    "prettier": "^3.8.4",
    "source-map-support": "^0.5.21",
    "split-file": "^2.3.1",
    "superagent": "^10.3.0",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0"
  }
}
